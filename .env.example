# Server
HOST=127.0.0.1
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Optional write protection. If set, dashboard write actions need this token.
STREAM_CHAT_ADMIN_TOKEN=

# Optional X API v2 bearer token for recent-search sync.
X_BEARER_TOKEN=

# Optional durable storage via Upstash Redis REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STREAM_CHAT_STATE_KEY=unified-stream-chat:messages

# Optional Kick webhook verification.
# If KICK_PUBLIC_KEY is set, incoming Kick webhooks must include valid Kick signature headers.
KICK_PUBLIC_KEY=
