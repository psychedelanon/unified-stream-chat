# Server
HOST=127.0.0.1
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# Optional write protection. If set, dashboard write actions need this token.
STREAM_CHAT_ADMIN_TOKEN=

# Optional X API v2 bearer token for recent-search sync.
X_BEARER_TOKEN=

# Optional durable storage via Upstash Redis REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STREAM_CHAT_STATE_KEY=unified-stream-chat:messages

# Optional Kick webhook verification.
# If KICK_PUBLIC_KEY is set, incoming Kick webhooks must include valid Kick signature headers.
# Get the key from: https://api.kick.com/public/v1/public-key
KICK_PUBLIC_KEY=

# One-click "connect account" OAuth. Required for /api/auth/{x,twitch,kick}/start.
# Generate AUTH_SESSION_SECRET / TOKEN_ENCRYPTION_KEY with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# X Developer Portal (confidential Web App, OAuth 2.0 enabled).
# Callback: {PUBLIC_BASE_URL}/api/auth/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
# X_REDIRECT_URI=            # optional override

# Twitch Developer Console (https://dev.twitch.tv/console/apps).
# Callback: {PUBLIC_BASE_URL}/api/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# TWITCH_REDIRECT_URI=       # optional override

# Kick Developer Portal (https://dev.kick.com/).
# Callback: {PUBLIC_BASE_URL}/api/auth/kick/callback
# App webhook URL: {PUBLIC_BASE_URL}/api/kick/webhook
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# KICK_REDIRECT_URI=         # optional override
